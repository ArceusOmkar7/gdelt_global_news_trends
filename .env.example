# ===========================================================
# GNIEM — Environment Variables
# ===========================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ===========================================================

# --- GCP / BigQuery ---
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# --- GDELT Dataset (defaults are fine for most cases) ---
GDELT_DATASET=gdelt-bq.gdeltv2
GDELT_TABLE=events_partitioned
HOT_TIER_PATH=./data/hot_tier
CACHE_PATH=./data/cache
HOT_TIER_CUTOFF_DAYS=90
COLD_TIER_MAX_WINDOW_DAYS=30
COLD_TIER_MONTHLY_QUERY_LIMIT=3
BQ_MAX_SCAN_BYTES=2000000000

# --- AI / LLM ---
LLM_MODEL_NAME=gemini-1.5-flash
GROQ_API_KEY=

# --- Query Defaults ---
DEFAULT_LOOKBACK_DAYS=7
DEFAULT_QUERY_LIMIT=10000

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# --- Frontend (Optional overrides) ---
# VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_token
# VITE_API_URL=http://localhost:8000/api/v1
